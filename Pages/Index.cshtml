@page
@model VehicleSubmissionApp.Pages.IndexModel

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="mb-3">🗂 Vehicle Submissions</h5>
            <form method="get">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Brand</label>
                        <select name="BrandFilter" id="brandFilter" class="form-select">
                            <option value="">All Brands</option>
                            @foreach (var b in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)Model.Brands)
                            {
                                <option value="@b.Value" selected="@(Model.BrandFilter.ToString() == b.Value)">@b.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Model</label>
                        <select name="ModelFilter" id="modelFilter" class="form-select">
                            <option value="">All Models</option>
                            @foreach (var m in (IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)Model.Models)
                            {
                                <option value="@m.Value" selected="@(Model.ModelFilter.ToString() == m.Value)">@m.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Search</label>
                        <div class="input-group">
                            <input type="text" name="Search" value="@Model.Search" class="form-control" placeholder="Search by name, email, phone, civil ID..." />
                            <button type="submit" class="btn btn-primary">Search</button>
                            <a href="/Index" class="btn btn-secondary">Reset</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Submissions.Any())
    {
        <div class="alert alert-info">No records found.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">
            @foreach (var s in Model.Submissions)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex gap-3">
                            <img src="@s.CivilIdImagePath" alt="Civil ID"
                                 style="width:80px;height:80px;object-fit:cover;border-radius:6px;" />
                            <div>
                                <p class="mb-1"><strong>Name:</strong> @s.Name</p>
                                <p class="mb-1"><strong>Civil ID:</strong> @s.CivilId</p>
                                <p class="mb-1"><strong>Phone:</strong> @(s.Phone ?? "-")</p>
                                <p class="mb-1"><strong>Email:</strong> @s.Email</p>
                                <p class="mb-1"><strong>Brand:</strong> @s.Brand.BrandName</p>
                                <p class="mb-0"><strong>Model:</strong> @s.Model.ModelName</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                Showing @((Model.PageNumber - 1) * Model.PageSize + 1)
                to @Math.Min(Model.PageNumber * Model.PageSize, Model.Submissions.Count + (Model.PageNumber - 1) * Model.PageSize)
            </small>
            <nav>
                <ul class="pagination mb-0">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               href="?BrandFilter=@Model.BrandFilter&ModelFilter=@Model.ModelFilter&Search=@Model.Search&PageNumber=@i">@i</a>
                        </li>
                    }
                </ul>
            </nav>
            <a href="/Submit" class="btn btn-success btn-sm">+ Add New</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        document.getElementById('brandFilter').addEventListener('change', function () {
            var brandId = this.value;
            var modelSelect = document.getElementById('modelFilter');
            modelSelect.innerHTML = '<option value="">All Models</option>';
            if (brandId) {
                fetch('/?handler=Models&brandId=' + brandId)
                    .then(r => r.json())
                    .then(data => {
                        data.forEach(m => {
                            var opt = document.createElement('option');
                            opt.value = m.id;
                            opt.text = m.modelName;
                            modelSelect.appendChild(opt);
                        });
                    });
            }
        });
    </script>
}